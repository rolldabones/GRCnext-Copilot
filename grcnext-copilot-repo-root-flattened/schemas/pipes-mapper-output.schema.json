{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rolldabones/GRCnext-Copilot/schemas/pipes-mapper-output.schema.json",
  "title": "GRCnext™ Pipes Mapper Output",
  "description": "Dependency Registry emission from the Pipes Mapper advisory tool. Consumed by Exit Prover, Data Switchboard Planner and Clean Market Exit Kit.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tool",
    "registry_version",
    "scope",
    "dependencies",
    "change_log"
  ],
  "properties": {
    "tool": {
      "type": "string",
      "const": "pipes_mapper",
      "description": "Emitting tool identifier."
    },
    "registry_version": {
      "type": "string",
      "description": "ISO 8601 timestamp, Asia/Seoul unless stated otherwise."
    },
    "scope": {
      "type": "string",
      "description": "Mapping scope: product, system, region or business function."
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "source",
          "destination",
          "criticality",
          "evidence_status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable identifier, for example PIPE-001."
          },
          "source": {
            "type": "string"
          },
          "destination": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "description": "Data or process carried by the pipe."
          },
          "type": {
            "type": "string",
            "enum": [
              "API",
              "ETL",
              "manual",
              "contractual",
              "financial",
              "other"
            ]
          },
          "criticality": {
            "type": "string",
            "enum": [
              "Critical",
              "High",
              "Standard"
            ]
          },
          "criticality_rationale": {
            "type": "string"
          },
          "owner": {
            "type": [
              "string",
              "null"
            ],
            "description": "Named role or team, or null for Unknown."
          },
          "clause_ref": {
            "type": [
              "string",
              "null"
            ]
          },
          "trigger_template": {
            "type": [
              "string",
              "null"
            ]
          },
          "evidence_status": {
            "type": "string",
            "enum": [
              "Verified",
              "Provisional",
              "Not demonstrated",
              "Contradicted",
              "Refuted",
              "Not applicable"
            ],
            "description": "GRCnext™ evidence classification."
          },
          "last_verified": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "provisional_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "source",
          "destination",
          "criticality",
          "evidence_status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable identifier, for example PIPE-001."
          },
          "source": {
            "type": "string"
          },
          "destination": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "description": "Data or process carried by the pipe."
          },
          "type": {
            "type": "string",
            "enum": [
              "API",
              "ETL",
              "manual",
              "contractual",
              "financial",
              "other"
            ]
          },
          "criticality": {
            "type": "string",
            "enum": [
              "Critical",
              "High",
              "Standard"
            ]
          },
          "criticality_rationale": {
            "type": "string"
          },
          "owner": {
            "type": [
              "string",
              "null"
            ],
            "description": "Named role or team, or null for Unknown."
          },
          "clause_ref": {
            "type": [
              "string",
              "null"
            ]
          },
          "trigger_template": {
            "type": [
              "string",
              "null"
            ]
          },
          "evidence_status": {
            "type": "string",
            "enum": [
              "Verified",
              "Provisional",
              "Not demonstrated",
              "Contradicted",
              "Refuted",
              "Not applicable"
            ],
            "description": "GRCnext™ evidence classification."
          },
          "last_verified": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "description": "Inferred entries not yet confirmed at CHECKPOINT."
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "change_log": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
