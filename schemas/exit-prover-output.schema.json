{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rolldabones/GRCnext-Copilot/schemas/exit-prover-output.schema.json",
  "title": "GRCnext™ Exit Prover Proof",
  "description": "Proof emission from the Exit Prover advisory tool. A proof with gaps reported honestly is a valid FAIL. Consumed by Clean Market Exit Kit.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tool",
    "proof_version",
    "scenario",
    "verdict",
    "dependencies",
    "switches",
    "obligations",
    "gaps",
    "feasible_72h"
  ],
  "properties": {
    "tool": {
      "type": "string",
      "const": "exit_prover",
      "description": "Emitting tool identifier."
    },
    "proof_version": {
      "type": "string",
      "description": "ISO 8601 timestamp, Asia/Seoul unless stated otherwise."
    },
    "scenario": {
      "type": "string"
    },
    "verdict": {
      "type": "string",
      "enum": [
        "PASS",
        "PROVISIONAL PASS",
        "FAIL"
      ],
      "description": "PROVISIONAL PASS caps any proof resting on unverified representations."
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "exit_action",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "exit_action": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "Verified",
              "Provisional",
              "Not demonstrated",
              "Contradicted",
              "Refuted",
              "Not applicable"
            ],
            "description": "GRCnext™ evidence classification."
          }
        }
      }
    },
    "switches": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "exists",
              "missing"
            ]
          },
          "flipped": {
            "type": "boolean"
          }
        }
      }
    },
    "obligations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "obligation",
          "owner",
          "status"
        ],
        "properties": {
          "obligation": {
            "type": "string"
          },
          "authority": {
            "type": "string",
            "description": "Cited only from user-supplied material; otherwise Unknown / Insufficient data."
          },
          "owner": {
            "type": "string"
          },
          "deadline": {
            "type": "string",
            "description": "Relative to T0, for example T+72h."
          },
          "evidence_required": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "Verified",
              "Provisional",
              "Not demonstrated",
              "Contradicted",
              "Refuted",
              "Not applicable"
            ],
            "description": "GRCnext™ evidence classification."
          }
        }
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "gap"
        ],
        "properties": {
          "gap": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "due": {
            "type": "string"
          }
        }
      }
    },
    "evidence_items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "feasible_72h": {
      "type": "boolean"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
