{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rolldabones/GRCnext-Copilot/schemas/switch-registry-output.schema.json",
  "title": "GRCnext™ Switch Registry Output",
  "description": "Registry and append-only log emission from the Switch Registry advisory tool. Flips record intent and evidence; actuation is human and out of scope. Consumed by Exit Prover, Treasury Reroute Planner, Data Switchboard Planner and Clean Market Exit Kit.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tool",
    "registry_version",
    "switches",
    "log",
    "change_log"
  ],
  "properties": {
    "tool": {
      "type": "string",
      "const": "switch_registry",
      "description": "Emitting tool identifier."
    },
    "registry_version": {
      "type": "string",
      "description": "ISO 8601 timestamp, Asia/Seoul unless stated otherwise."
    },
    "switches": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "status",
          "evidence_status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable identifier, for example SW-001."
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "ON",
              "OFF"
            ]
          },
          "owner": {
            "type": [
              "string",
              "null"
            ]
          },
          "linked_pipe_or_exit": {
            "type": [
              "string",
              "null"
            ]
          },
          "clause_ref": {
            "type": [
              "string",
              "null"
            ],
            "description": "Governing authority, for example a policy section."
          },
          "trigger_template": {
            "type": [
              "string",
              "null"
            ]
          },
          "approval_required": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notify": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "last_used": {
            "type": [
              "string",
              "null"
            ]
          },
          "evidence_status": {
            "type": "string",
            "enum": [
              "Verified",
              "Provisional",
              "Not demonstrated",
              "Contradicted",
              "Refuted",
              "Not applicable"
            ],
            "description": "GRCnext™ evidence classification."
          }
        }
      }
    },
    "log": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "timestamp",
          "switch_id",
          "action",
          "actor"
        ],
        "properties": {
          "timestamp": {
            "type": "string",
            "description": "ISO 8601."
          },
          "switch_id": {
            "type": "string"
          },
          "action": {
            "type": "string",
            "enum": [
              "ON->OFF",
              "OFF->ON"
            ]
          },
          "actor": {
            "type": "string"
          },
          "reason_or_incident_id": {
            "type": "string"
          },
          "approvals_recorded": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Recorded verbatim; validity not asserted by the tool."
          }
        }
      }
    },
    "last_flip": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "change_log": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
