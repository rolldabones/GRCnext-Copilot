{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rolldabones/GRCnext-Copilot/schemas/treasury-reroute-plan.schema.json",
  "title": "GRCnext™ Treasury Reroute Plan",
  "description": "Plan emission from the Treasury Reroute Planner advisory tool. Plans and documents only; never records execution of any transfer. Account identifiers masked to last four characters. Consumed by Clean Market Exit Kit.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tool",
    "plan_version",
    "scenario",
    "affected_flows",
    "routes",
    "steps",
    "72h_feasible",
    "drill"
  ],
  "properties": {
    "tool": {
      "type": "string",
      "const": "treasury_reroute_planner",
      "description": "Emitting tool identifier."
    },
    "plan_version": {
      "type": "string",
      "description": "ISO 8601 timestamp, Asia/Seoul unless stated otherwise."
    },
    "scenario": {
      "type": "string"
    },
    "affected_flows": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "flow",
          "primary"
        ],
        "properties": {
          "flow": {
            "type": "string"
          },
          "primary": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "institution",
              "status"
            ],
            "properties": {
              "institution": {
                "type": "string",
                "description": "Neutral label unless the user supplied the name."
              },
              "account": {
                "type": "string",
                "description": "Masked to last four characters."
              },
              "status": {
                "type": "string"
              },
              "evidence_status": {
                "type": "string",
                "enum": [
                  "Verified",
                  "Provisional",
                  "Not demonstrated",
                  "Contradicted",
                  "Refuted",
                  "Not applicable"
                ],
                "description": "GRCnext™ evidence classification."
              }
            }
          },
          "backup": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "institution",
              "status"
            ],
            "properties": {
              "institution": {
                "type": "string",
                "description": "Neutral label unless the user supplied the name."
              },
              "account": {
                "type": "string",
                "description": "Masked to last four characters."
              },
              "status": {
                "type": "string"
              },
              "evidence_status": {
                "type": "string",
                "enum": [
                  "Verified",
                  "Provisional",
                  "Not demonstrated",
                  "Contradicted",
                  "Refuted",
                  "Not applicable"
                ],
                "description": "GRCnext™ evidence classification."
              }
            }
          },
          "switch": {
            "type": [
              "string",
              "null"
            ]
          },
          "approval_required": {
            "type": [
              "string",
              "null"
            ]
          },
          "eta_hours": {
            "type": [
              "number",
              "null"
            ]
          }
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "order",
          "step",
          "owner",
          "status"
        ],
        "properties": {
          "order": {
            "type": "integer"
          },
          "step": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "done",
              "blocked"
            ]
          }
        }
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string",
        "description": "Advisory notes only."
      }
    },
    "72h_feasible": {
      "type": "boolean"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "drill": {
      "type": "boolean"
    }
  }
}
